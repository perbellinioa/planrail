{
  "name": "planrail",
  "version": "0.1.0",
  "description": "Minimal MCP server that enforces DAG-based plan execution for LLM agent fleets. Local, private, zero network calls.",
  "keywords": [
    "mcp",
    "dag",
    "orchestrator",
    "llm",
    "agent",
    "plan",
    "guardrails"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "planrail": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "benchmark": "npx tsx benchmark/run.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "network": false
}
